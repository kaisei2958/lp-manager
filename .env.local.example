# ==========================================
# Supabase (必須)
# Project Settings > API からコピー
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# Backlog (任意 - Backlog連携を使う場合)
# ==========================================
# スペースキー: https://{BACKLOG_SPACE_KEY}.backlog.com
BACKLOG_SPACE_KEY=yourcompany
# APIキー: Backlog 個人設定 > API > 新しいAPIキーを発行
BACKLOG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# Slack (任意 - Slack連携を使う場合)
# ==========================================
# Bot Token: api.slack.com > Your Apps > OAuth & Permissions > Bot User OAuth Token
# 必要なスコープ: channels:history, groups:history, channels:read, users:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
